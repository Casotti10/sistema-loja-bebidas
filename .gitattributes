# Normaliza quebras de linha em todo o repositório.
# Regra geral: o Git detecta arquivos de texto e os armazena com LF.
* text=auto eol=lf

# Arquivos de texto que DEVEM ser LF (scripts e web quebram no Linux com CRLF).
*.js    text eol=lf
*.ts    text eol=lf
*.jsx   text eol=lf
*.tsx   text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.css   text eol=lf
*.scss  text eol=lf
*.html  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.sh    text eol=lf
*.env   text eol=lf

# Arquivos binários: o Git NUNCA deve mexer nas quebras de linha deles.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.pdf   binary
*.woff  binary
*.woff2 binary